# Server Configuration
# ========================================

# 服务端口
# 默认值: 65002
PORT=65002

# Node 环境
# 可选值: development, production
NODE_ENV=development

# 数据存储目录
# 默认值: ./data
DATA_DIR=./data


# JWT Configuration
# ========================================

# JWT 密钥（同时也用作密码加密密钥，请妥善保管）
# 默认值: your-secret-key-change-in-production
JWT_SECRET=your-secret-key-change-in-production

# JWT 过期时间
# 可选格式: 60, "2 days", "10h", "7d"
# 默认值: 7d
JWT_EXPIRES_IN=7d


# Aria2 Configuration
# ========================================

# Aria2 RPC 地址
# 默认值: http://localhost:6800/jsonrpc
ARIA2_RPC_URL=http://localhost:6800/jsonrpc

# Aria2 RPC 密钥
# 为空表示不使用密钥
ARIA2_SECRET=


# Registration Configuration
# ========================================

# 是否启用 Web 注册接口
# 可选值: true, false
# 默认值: false
ENABLE_REGISTER=false