{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "noImplicitAny": false,
    "paths": {
      "@common/*": ["../common/*"]
    }
  },
  "include": ["src/**/*", "../common/**/*"],
  "exclude": ["node_modules", "dist", "tsup.config.ts"]
}